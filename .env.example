APP__ENV=development
APP__NAME=ReviewAgent PTIT
APP__HOST=0.0.0.0
APP__PORT=8000
APP__LOG_LEVEL=INFO

# Database Connection Details
DATABASE__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reviewagent

# Postgres Container Configuration (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reviewagent

REDIS__URL=redis://localhost:6379/0
REDIS__CMS_TTL_SECONDS=86400

ORCID__CLIENT_ID=
ORCID__CLIENT_SECRET=
ORCID__TOKEN_URL=https://orcid.org/oauth/token
ORCID__API_BASE_URL=https://pub.orcid.org/v3.0

CELERY__BROKER_URL=redis://localhost:6379/1
CELERY__RESULT_BACKEND=redis://localhost:6379/2
CELERY__TASK_DEFAULT_QUEUE=reviewagent

SNAPSHOT__MJL_PATH=snapshots/mjl_current.csv
SNAPSHOT__SCIMAGO_PATH=snapshots/scimago_jcr.csv
SNAPSHOT__BEALL_PATH=snapshots/beall.csv
SNAPSHOT__DOAJ_PATH=snapshots/doaj.csv

AUDIT__SECRET_KEY=

THRESHOLD__AUTO_APPROVE=0.90
THRESHOLD__AUTO_REJECT=0.65

APIS__CROSSREF_BASE_URL=https://api.crossref.org
APIS__OPENALEX_BASE_URL=https://api.openalex.org

LLM__PROVIDER=openrouter
LLM__API_KEY=
LLM__MODEL=nvidia/nemotron-3-super-120b-a12b:free
LLM__OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM__TIMEOUT_SECONDS=60
LLM__SELF_CONSISTENCY_K=3
LLM__COVE_ENABLED=true
